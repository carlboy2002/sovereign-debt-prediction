# ── Sensitive / Personal ─────────────────────────────────────
# Never commit credentials or personal config
*.env
.env.*
!.env.example
secrets.json
credentials.json
service-account*.json
*-credentials.json
google-credentials.json

# Google Cloud SDK auth (usually in ~/.config/gcloud/ but just in case)
application_default_credentials.json

# Personal config — uses config.example.py template
.local_config.py

# ── Data (too large for git, and reproducible) ──────────────
# Raw data: downloaded from external sources, reproducible via scripts
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.tif
data/raw/nl_*.csv
data/raw/nightlights_*.csv

# Processed data: regenerated by running scripts
data/processed/*.csv
data/processed/*.json

# But keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Python cache / build ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# ── IDE / OS ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter / Notebooks ─────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Virtual environments ────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Temporary files ─────────────────────────────────────────
*.log
*.tmp
*.bak
temp/
tmp/

# ── GEE auth tokens (sometimes cached locally) ──────────────
.config/earthengine/

config.py
config.py.backup